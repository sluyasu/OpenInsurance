# openinsurance-wiki - extraction LLM configuration
# Copy to `.env` and fill in the provider + key for the model you want to use.
# The pipeline is provider-agnostic: only these values change, never the prompts
# (see extraction-agent/). Bring your own model; nothing paid is hard-wired.

# Which provider adapter to use: anthropic | gemini | openai | local
LLM_PROVIDER=anthropic

# Model id for the chosen provider. Examples (verify current ids with each provider):
#   anthropic -> claude-sonnet-5
#   gemini    -> gemini-2.5-flash
#   openai    -> gpt-5
#   local     -> a model name served by your local Ollama (e.g. llama3.1:70b)
LLM_MODEL=claude-sonnet-5

# API keys - set only the one for your chosen provider.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# For LLM_PROVIDER=local (Ollama). Default assumes a local Ollama server.
OLLAMA_HOST=http://localhost:11434

# Extraction tuning (optional)
LLM_MAX_OUTPUT_TOKENS=16000
LLM_TEMPERATURE=0
