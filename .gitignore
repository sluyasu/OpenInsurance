# Downloaded PDFs are large binaries - regenerable from sources/ via `make download`.
# The manifest (provenance: url, checksum, date) IS committed; the PDFs are not.
data/**/pdfs/

# Static site build (generated in CI from wiki/, never committed)
site/
site-src/

# Python packaging
dist/
build/
*.egg-info/

# Secrets
.env

# Python
.venv/
venv/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/

# Playwright
.playwright/

# OS / editor
.DS_Store
.idea/
.vscode/

# Node (only if a static site is added later)
node_modules/

# Obsidian per-user workspace state and stray notes (the wiki is generated/authored,
# not a personal vault: daily notes and canvases are accidental local artifacts).
.obsidian/
*.canvas
wiki/[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9].md
