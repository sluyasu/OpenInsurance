    "accidents_corporels": {"label": "Accidents corporels", "keywords": ["accident corporel", "dommages corporels", "lichamelijk", "invalidite", "deces"]},
    "relogement": {"label": "Relogement / frais supplémentaires", "keywords": ["relogement", "frais supplementaires", "frais de sauvetage", "herhuisvesting"]},
    "rc_immeuble": {"label": "RC immeuble / bâtiment", "keywords": ["rc immeuble", "responsabilite du batiment", "trouble de voisinage"]},
    "animaux": {"label": "Dommages / responsabilité animaux", "keywords": ["animaux", "animal", "dieren"]}
  }
}
